// hello.joe: GUI hello world
var name = Console.args().isEmpty()
    ? "world" : Console.args().get(0);

var root = VBox()
    .set(#alignment, #center)
    .spacing(10)
    .child(Label("Hello, " + name + "!"))
    .child(Button("Goodbye")
        .action(\-> Console.exit(0))
    )
    ;

var scene = Scene(root, 300, 150);
var stage = Stage()
    .scene(scene)
    .title("joe win: Hello")
    .show();

